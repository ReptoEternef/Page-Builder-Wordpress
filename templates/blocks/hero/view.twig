{# HERO #}

{% if values.layout == layouts[0] %}
<div class="{{block}} {{ block }}-{{ layouts[0] }}" style="background-image:url({{ values.background }})">
	<div class="content">
		<h1>{{ values.title[lang] }}</h1>
		<p>{{ values.slogan[lang] }}</p>
		<div class="content-btns">
			<a href="{{ values.btn1_link[lang] }}" class="button empty-btn first-btn">{{ values.btn1[lang] }}</a>
			<a href="{{ values.btn2_link[lang] }}" class="button empty-btn second-btn">{{ values.btn2[lang] }}</a>
		</div>
	</div>

	<a href="#bio" id="btn-down-hero">
		<dotlottie-player
			src="/wp-content/themes/Page-Builder-Wordpress-master/assets/images/lotties/Swipe_up_Arrows.json"
			background="transparent"
			speed="1"
			style="width: 15vh; height: 15vh;"
			loop
			autoplay>
		</dotlottie-player>
	</a>
</div>
{% elseif values.layout == layouts[1] %}
<div class="{{ block }}-{{ layouts[1] }}" style="background-image:url({{ values.background }})">
	<div class="content-wrapper contained">	
		<div class="content">
			<h1>{{ values.slogan[lang] }}</h1>
			<p>{{ values.subtitle[lang] }}</p>
		</div>
	</div>
</div>  
{% else %}
	<span>Erreur : layout</span>
{% endif %}


