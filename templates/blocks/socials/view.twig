{# BLOC NAME #}

{% if values.layout == layouts[0] %}
<div class="{{ block }}-{{ layouts[0] }}">

	{% if values.instagram %}
		<a href="{{ values.instagram }}" target="_blank">{% include 'templates/blocks/socials/assets/icons/skill-icons--instagram.svg' %}</a>
	{% endif %}

	{% if values.facebook %}
		<a href="{{ values.facebook }}" target="_blank">{% include 'templates/blocks/socials/assets/icons/logos--facebook.svg' %}</a>
	{% endif %}

	{% if values.youtube %}
		<a href="{{ values.youtube }}" target="_blank">{% include 'templates/blocks/socials/assets/icons/logos--youtube-icon.svg' %}</a>
	{% endif %}
</div>
{% elseif values.layout == layouts[1] %}
<div class="{{ block }}-{{ layouts[1] }}">

</div>  
{% else %}
<span>Erreur : layout</span>
{% endif %}


